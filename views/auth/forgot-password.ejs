<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card mt-5">
      <div class="card-header text-center">
        <i class="bi bi-envelope"></i> 忘記密碼
      </div>
      <div class="card-body p-4">
        <p class="text-muted">輸入您的 Email，我們會寄送重設密碼連結給您。</p>
        <form action="/auth/forgot-password" method="POST">
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" name="email" id="email" class="form-control" placeholder="請輸入註冊時的 Email" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">寄送重設連結</button>
        </form>
        <p class="text-center mt-3 mb-0">
          <a href="/auth/login">返回登入</a>
        </p>
      </div>
    </div>
  </div>
</div>
