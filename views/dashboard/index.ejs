<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-0"><i class="bi bi-calendar-week"></i> <%= year %> 行事曆</h2>
  </div>
  <div class="d-flex align-items-center gap-2">
    <% if (isManager && salesReps.length > 0) { %>
      <select id="repSelector" class="form-select form-select-sm" style="width: auto;"
        onchange="location.href='<%= view === 'month' ? '/month?month=' + currentMonth : '/?week=' + currentWeek %>&rep=' + this.value">
        <% salesReps.forEach(rep => { %>
          <option value="<%= rep._id %>" <%= rep._id.toString() === selectedRep ? 'selected' : '' %>>
            <%= rep.name %>
          </option>
        <% }) %>
      </select>
    <% } %>

    <!-- 週/月切換 -->
    <div class="btn-group btn-group-sm">
      <a href="/<%= selectedRep && isManager ? '?rep=' + selectedRep : '' %>" class="btn <%= view === 'week' ? 'btn-primary' : 'btn-outline-primary' %>">週</a>
      <a href="/month<%= selectedRep && isManager ? '?rep=' + selectedRep : '' %>" class="btn <%= view === 'month' ? 'btn-primary' : 'btn-outline-primary' %>">月</a>
    </div>

    <% if (view === 'week') { %>
      <a href="/<%= isManager && selectedRep ? '?rep=' + selectedRep : '' %>" class="btn btn-primary btn-sm">
        <i class="bi bi-calendar-check"></i> 本週
      </a>
      <a href="/?week=<%= prevWeek %><%= isManager && selectedRep ? '&rep=' + selectedRep : '' %>" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-chevron-left"></i>
      </a>
      <span class="fw-bold text-primary"><%= weekLabel %></span>
      <a href="/?week=<%= nextWeek %><%= isManager && selectedRep ? '&rep=' + selectedRep : '' %>" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-chevron-right"></i>
      </a>
    <% } else { %>
      <a href="/month<%= isManager && selectedRep ? '?rep=' + selectedRep : '' %>" class="btn btn-primary btn-sm">
        <i class="bi bi-calendar-check"></i> 本月
      </a>
      <a href="/month?month=<%= prevMonth %><%= isManager && selectedRep ? '&rep=' + selectedRep : '' %>" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-chevron-left"></i>
      </a>
      <span class="fw-bold text-primary"><%= monthLabel %></span>
      <a href="/month?month=<%= nextMonth %><%= isManager && selectedRep ? '&rep=' + selectedRep : '' %>" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-chevron-right"></i>
      </a>
    <% } %>
  </div>
</div>

<% if (view === 'week') { %>
<!-- ===== 週檢視 ===== -->
<div class="table-responsive">
  <table class="table table-bordered calendar-table">
    <thead>
      <tr>
        <th class="time-col">時間</th>
        <% weekDays.forEach(day => { %>
          <th class="day-col text-center"><%= day.label %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% timeSlots.forEach(slot => { %>
        <tr>
          <td class="time-col text-center fw-bold"><%= slot %></td>
          <% weekDays.forEach(day => { %>
            <%
              const key = day.date + '_' + slot;
              const cellVisits = visitMap[key] || [];
              const isOccupied = occupiedSlots[key] && occupiedSlots[key].length > 0;
            %>
            <td class="calendar-cell <%= isOccupied ? 'occupied-cell' : '' %>" data-date="<%= day.date %>" data-slot="<%= slot %>"
              onclick="openAddModal('<%= day.date %>', '<%= slot %>')">
              <% cellVisits.forEach(v => { %>
                <% const dur = v.duration || 1; %>
                <% if (v.source === 'google') { %>
                  <div class="visit-card visit-google" title="<%= v.content || '' %>"
                    style="<%= dur > 1 ? 'height:' + (dur * 61 - 5) + 'px; position:relative; z-index:2;' : '' %>">
                    <div class="visit-card-name"><i class="bi bi-google"></i> <%= v.content ? v.content.split('\n')[0] : 'Google 事件' %></div>
                  </div>
                <% } else { %>
                  <div class="visit-card <%= v.client ? 'visit-' + v.status : 'visit-nonvisit' %>"
                    onclick="event.stopPropagation(); openEditModal('<%= v._id %>')"
                    style="<%= dur > 1 ? 'height:' + (dur * 61 - 5) + 'px; position:relative; z-index:2;' : '' %>">
                    <div class="visit-card-name"><%= v.client ? v.client.name : (v.content ? v.content.split('\n')[0] : '工作事項') %></div>
                    <span class="badge badge-<%= v.status %>">
                      <%= v.status === 'scheduled' ? '預排' : v.status === 'visited' ? '已訪' : '取消' %>
                    </span>
                    <% if (dur > 1) { %>
                      <small class="text-muted d-block"><%= dur %> 小時</small>
                    <% } %>
                  </div>
                <% } %>
              <% }) %>
            </td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<% } else { %>
<!-- ===== 月檢視 ===== -->
<div class="table-responsive">
  <table class="table table-bordered calendar-table month-table">
    <thead>
      <tr>
        <% dayNames.forEach(d => { %>
          <th class="text-center"><%= d %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% weeks.forEach(week => { %>
        <tr>
          <% week.forEach(day => { %>
            <td class="month-cell <%= day.isCurrentMonth ? '' : 'text-muted bg-light' %>"
              onclick="openAddModal('<%= day.date %>', '09:00')">
              <div class="month-day-number"><%= day.day %></div>
              <% day.visits.slice(0, 4).forEach(v => { %>
                <% if (v.source === 'google') { %>
                  <div class="month-event month-event-google" title="<%= v.content || '' %>">
                    <small><%= v.timeSlot %> <%= v.content ? v.content.split('\n')[0] : 'Google' %></small>
                  </div>
                <% } else { %>
                  <div class="month-event month-event-<%= v.status %>"
                    onclick="event.stopPropagation(); openEditModal('<%= v._id %>')" title="<%= v.client ? v.client.name : '' %>">
                    <small><%= v.timeSlot %> <%= v.client ? v.client.name : (v.content ? v.content.split('\n')[0] : '') %></small>
                  </div>
                <% } %>
              <% }) %>
              <% if (day.visits.length > 4) { %>
                <div class="text-muted" style="font-size:0.7rem;">+<%= day.visits.length - 4 %> 更多</div>
              <% } %>
            </td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<!-- 新增拜訪 Modal -->
<div class="modal fade" id="addVisitModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> <span id="addModalTitle">新增拜訪行程</span></h5>
        <div class="ms-auto me-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" id="toggleVisitType" onclick="toggleAddMode()">
            <i class="bi bi-arrow-left-right"></i> <span id="toggleLabel">非拜訪行程</span>
          </button>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/visits" method="POST" onsubmit="if(document.getElementById('addIsNonVisit').value==='1'){document.getElementById('addContent').value=document.getElementById('addNonVisitContent').value;}">
        <div class="modal-body">
          <input type="hidden" name="date" id="addDate">
          <input type="hidden" name="timeSlot" id="addTimeSlot">
          <input type="hidden" name="isNonVisit" id="addIsNonVisit" value="">
          <div class="row mb-3">
            <div class="col-8">
              <label class="form-label">日期 / 時間</label>
              <div class="form-control-plaintext fw-bold" id="addDateTimeDisplay"></div>
            </div>
            <div class="col-4">
              <label for="addDuration" class="form-label">時間長度</label>
              <select name="duration" id="addDuration" class="form-select form-select-sm">
                <option value="1" selected>1 小時</option>
                <option value="2">2 小時</option>
                <option value="3">3 小時</option>
                <option value="4">4 小時</option>
              </select>
            </div>
          </div>
          <!-- 拜訪行程區塊 -->
          <div id="visitSection">
            <div class="mb-3">
              <label for="clientSearch" class="form-label">選擇客戶（診所）</label>
              <input type="text" id="clientSearch" class="form-control" placeholder="輸入名稱搜尋..." autocomplete="off">
              <input type="hidden" name="clientId" id="addClientId">
              <div id="clientResults" class="list-group mt-1" style="position:absolute; z-index:1000; width:calc(100% - 2rem);"></div>
            </div>
            <div id="clientInfo" class="alert alert-light" style="display:none;">
              <div><strong>客戶：</strong><span id="ciName"></span></div>
              <div><strong>電話：</strong><span id="ciPhone"></span></div>
              <div><strong>地址：</strong><span id="ciAddress"></span></div>
            </div>
            <!-- 快速新增客戶 -->
            <div id="quickCreateClient" class="card border-primary mb-3" style="display:none;">
              <div class="card-header bg-primary text-white py-2">
                <i class="bi bi-plus-circle"></i> 新增客戶
              </div>
              <div class="card-body">
                <div class="mb-2">
                  <label class="form-label form-label-sm mb-1">診所名稱 <span class="text-danger">*</span></label>
                  <input type="text" id="qcName" class="form-control form-control-sm">
                </div>
                <div class="mb-2">
                  <label class="form-label form-label-sm mb-1">電話</label>
                  <input type="text" id="qcPhone" class="form-control form-control-sm">
                </div>
                <div class="mb-2">
                  <label class="form-label form-label-sm mb-1">地址</label>
                  <input type="text" id="qcAddress" class="form-control form-control-sm">
                </div>
                <button type="button" class="btn btn-primary btn-sm w-100" id="qcSubmitBtn" onclick="quickCreateClient()">
                  <i class="bi bi-check-lg"></i> 建立並選擇此客戶
                </button>
              </div>
            </div>
            <div class="mb-3">
              <label for="addContent" class="form-label">拜訪事項</label>
              <textarea name="content" id="addContent" class="form-control" rows="3" placeholder="預計拜訪的事項..."></textarea>
            </div>
          </div>
          <!-- 非拜訪行程區塊 -->
          <div id="nonVisitSection" style="display:none;">
            <div class="mb-3">
              <label for="addNonVisitContent" class="form-label">工作事項</label>
              <textarea id="addNonVisitContent" class="form-control" rows="4" placeholder="例：開會、教育訓練、行政事務..."></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary" id="addSubmitBtn" disabled>新增行程</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 編輯拜訪 Modal -->
<div class="modal fade" id="editVisitModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil-square"></i> 拜訪紀錄</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="editVisitForm" method="POST">
        <input type="hidden" name="_method" value="PUT">
        <div class="modal-body">
          <div class="row mb-3">
            <div class="col-md-4">
              <label class="form-label">客戶</label>
              <div class="form-control-plaintext fw-bold" id="editClientName"></div>
            </div>
            <div class="col-md-4">
              <label class="form-label">狀態</label>
              <select name="status" id="editStatus" class="form-select">
                <option value="scheduled">預排行程</option>
                <option value="visited">已拜訪</option>
                <option value="cancelled">取消行程</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">時間長度</label>
              <select name="duration" id="editDuration" class="form-select">
                <option value="1">1 小時</option>
                <option value="2">2 小時</option>
                <option value="3">3 小時</option>
                <option value="4">4 小時</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <div class="col-md-6">
              <div><i class="bi bi-telephone"></i> <span id="editClientPhone"></span></div>
            </div>
            <div class="col-md-6">
              <div><i class="bi bi-geo-alt"></i> <span id="editClientAddress"></span></div>
            </div>
          </div>
          <hr>
          <div class="mb-3">
            <label for="editContactPerson" class="form-label">拜訪對象</label>
            <input type="text" name="contactPerson" id="editContactPerson" class="form-control" placeholder="例：王醫師">
          </div>
          <div class="mb-3">
            <label for="editContent" class="form-label">拜訪內容</label>
            <textarea name="content" id="editContent" class="form-control" rows="4" placeholder="拜訪內容紀錄..."></textarea>
          </div>
          <div class="mb-3">
            <label for="editFollowUp" class="form-label">追蹤事項</label>
            <textarea name="followUp" id="editFollowUp" class="form-control" rows="2" placeholder="需追蹤的事項..."></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-danger me-auto" id="deleteVisitBtn">
            <i class="bi bi-trash"></i> 刪除
          </button>
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">儲存紀錄</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 油資申報提示 Modal -->
<div class="modal fade" id="mileagePromptModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-fuel-pump"></i> 申報油資</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted mb-3">拜訪紀錄已儲存，是否申報此次交通油資？</p>
        <div class="mb-3">
          <label class="form-label fw-bold"><i class="bi bi-geo-alt text-primary"></i> 出發地</label>
          <input type="text" id="mileageOrigin" class="form-control" value="">
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold"><i class="bi bi-geo-alt-fill text-danger"></i> 拜訪地</label>
          <input type="text" id="mileageDestination" class="form-control" value="">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">不申報油資</button>
        <a id="mileageLink" href="#" class="btn btn-primary"><i class="bi bi-fuel-pump"></i> 申報油資</a>
      </div>
    </div>
  </div>
</div>

<script src="/js/calendar.js"></script>
<script>
  const urlParams = new URLSearchParams(window.location.search);
  const showMileageId = urlParams.get('showMileage');
  if (showMileageId) {
    const originInput = document.getElementById('mileageOrigin');
    const destInput = document.getElementById('mileageDestination');
    const mileageLink = document.getElementById('mileageLink');
    const defaultOrigin = '<%= process.env.COMPANY_ADDRESS || "台北市羅斯福路三段136號" %>';

    function updateMileageLink() {
      const origin = encodeURIComponent(originInput.value);
      const dest = encodeURIComponent(destInput.value);
      mileageLink.href = '/mileage/confirm?visitId=' + showMileageId + '&origin=' + origin + '&destination=' + dest;
    }

    originInput.addEventListener('input', updateMileageLink);
    destInput.addEventListener('input', updateMileageLink);

    // 取得拜訪詳情填入 modal
    fetch('/visits/' + showMileageId + '/json')
      .then(r => r.json())
      .then(visit => {
        originInput.value = visit.prevVisitAddress || defaultOrigin;
        destInput.value = visit.client && visit.client.address ? visit.client.address : '';
        updateMileageLink();
        new bootstrap.Modal(document.getElementById('mileagePromptModal')).show();
      })
      .catch(() => {
        originInput.value = defaultOrigin;
        updateMileageLink();
        new bootstrap.Modal(document.getElementById('mileagePromptModal')).show();
      });
  }
</script>
