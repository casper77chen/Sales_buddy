<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-0"><i class="bi bi-calendar-week"></i> <%= year %> 週行事曆</h2>
  </div>
  <div class="d-flex align-items-center gap-2">
    <% if (isManager && salesReps.length > 0) { %>
      <select id="repSelector" class="form-select form-select-sm" style="width: auto;"
        onchange="location.href='/?week=<%= currentWeek %>&rep=' + this.value">
        <% salesReps.forEach(rep => { %>
          <option value="<%= rep._id %>" <%= rep._id.toString() === selectedRep ? 'selected' : '' %>>
            <%= rep.name %>
          </option>
        <% }) %>
      </select>
    <% } %>
    <a href="/<%= isManager && selectedRep ? '?rep=' + selectedRep : '' %>" class="btn btn-primary btn-sm">
      <i class="bi bi-calendar-check"></i> 本週
    </a>
    <a href="/?week=<%= prevWeek %><%= isManager && selectedRep ? '&rep=' + selectedRep : '' %>" class="btn btn-outline-primary btn-sm">
      <i class="bi bi-chevron-left"></i>
    </a>
    <span class="fw-bold text-primary"><%= weekLabel %></span>
    <a href="/?week=<%= nextWeek %><%= isManager && selectedRep ? '&rep=' + selectedRep : '' %>" class="btn btn-outline-primary btn-sm">
      <i class="bi bi-chevron-right"></i>
    </a>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-bordered calendar-table">
    <thead>
      <tr>
        <th class="time-col">時間</th>
        <% weekDays.forEach(day => { %>
          <th class="day-col text-center"><%= day.label %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% timeSlots.forEach(slot => { %>
        <tr>
          <td class="time-col text-center fw-bold"><%= slot %></td>
          <% weekDays.forEach(day => { %>
            <%
              const key = day.date + '_' + slot;
              const cellVisits = visitMap[key] || [];
            %>
            <td class="calendar-cell" data-date="<%= day.date %>" data-slot="<%= slot %>"
              onclick="openAddModal('<%= day.date %>', '<%= slot %>')">
              <% cellVisits.forEach(v => { %>
                <div class="visit-card visit-<%= v.status %>"
                  onclick="event.stopPropagation(); openEditModal('<%= v._id %>')">
                  <div class="visit-card-name"><%= v.client ? v.client.name : '未知客戶' %></div>
                  <span class="badge badge-<%= v.status %>">
                    <%= v.status === 'scheduled' ? '預排' : v.status === 'visited' ? '已訪' : '取消' %>
                  </span>
                </div>
              <% }) %>
            </td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- 新增拜訪 Modal -->
<div class="modal fade" id="addVisitModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> 新增拜訪行程</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/visits" method="POST">
        <div class="modal-body">
          <input type="hidden" name="date" id="addDate">
          <input type="hidden" name="timeSlot" id="addTimeSlot">
          <div class="mb-3">
            <label class="form-label">日期 / 時間</label>
            <div class="form-control-plaintext fw-bold" id="addDateTimeDisplay"></div>
          </div>
          <div class="mb-3">
            <label for="clientSearch" class="form-label">選擇客戶（診所）</label>
            <input type="text" id="clientSearch" class="form-control" placeholder="輸入名稱搜尋..." autocomplete="off">
            <input type="hidden" name="clientId" id="addClientId">
            <div id="clientResults" class="list-group mt-1" style="position:absolute; z-index:1000; width:calc(100% - 2rem);"></div>
          </div>
          <div id="clientInfo" class="alert alert-light" style="display:none;">
            <div><strong>客戶：</strong><span id="ciName"></span></div>
            <div><strong>電話：</strong><span id="ciPhone"></span></div>
            <div><strong>地址：</strong><span id="ciAddress"></span></div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary" id="addSubmitBtn" disabled>新增行程</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 編輯拜訪 Modal -->
<div class="modal fade" id="editVisitModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil-square"></i> 拜訪紀錄</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="editVisitForm" method="POST">
        <input type="hidden" name="_method" value="PUT">
        <div class="modal-body">
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">客戶</label>
              <div class="form-control-plaintext fw-bold" id="editClientName"></div>
            </div>
            <div class="col-md-6">
              <label class="form-label">狀態</label>
              <select name="status" id="editStatus" class="form-select">
                <option value="scheduled">預排行程</option>
                <option value="visited">已拜訪</option>
                <option value="cancelled">取消行程</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <div class="col-md-6">
              <div><i class="bi bi-telephone"></i> <span id="editClientPhone"></span></div>
            </div>
            <div class="col-md-6">
              <div><i class="bi bi-geo-alt"></i> <span id="editClientAddress"></span></div>
            </div>
          </div>
          <hr>
          <div class="mb-3">
            <label for="editContactPerson" class="form-label">拜訪對象</label>
            <input type="text" name="contactPerson" id="editContactPerson" class="form-control" placeholder="例：王醫師">
          </div>
          <div class="mb-3">
            <label for="editContent" class="form-label">拜訪內容</label>
            <textarea name="content" id="editContent" class="form-control" rows="4" placeholder="拜訪內容紀錄..."></textarea>
          </div>
          <div class="mb-3">
            <label for="editFollowUp" class="form-label">追蹤事項</label>
            <textarea name="followUp" id="editFollowUp" class="form-control" rows="2" placeholder="需追蹤的事項..."></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-danger me-auto" id="deleteVisitBtn">
            <i class="bi bi-trash"></i> 刪除
          </button>
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">儲存紀錄</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 油資申報提示 Modal -->
<div class="modal fade" id="mileagePromptModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-fuel-pump"></i> 是否申報油資？</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>拜訪紀錄已儲存。是否要申報此次拜訪的交通油資？</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">稍後再說</button>
        <a id="mileageLink" href="#" class="btn btn-primary"><i class="bi bi-fuel-pump"></i> 申報油資</a>
      </div>
    </div>
  </div>
</div>

<script src="/js/calendar.js"></script>

<%
  // 檢查是否需要顯示油資提示
  const showMileageId = typeof require !== 'undefined' ? '' : '';
%>
<script>
  // 從 URL 參數取得 showMileage
  const urlParams = new URLSearchParams(window.location.search);
  const showMileageId = urlParams.get('showMileage');
  if (showMileageId) {
    document.getElementById('mileageLink').href = '/mileage/confirm?visitId=' + showMileageId;
    new bootstrap.Modal(document.getElementById('mileagePromptModal')).show();
  }
</script>
