<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-gear"></i> 使用者管理</h2>
</div>

<% const pendingUsers = users.filter(u => !u.isApproved); %>
<% if (pendingUsers.length > 0) { %>
  <div class="card mb-4 border-warning">
    <div class="card-header bg-warning text-dark">
      <i class="bi bi-clock-history"></i> 待審核帳號（<%= pendingUsers.length %>）
    </div>
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>姓名</th>
            <th>Email</th>
            <th>申請角色</th>
            <th>註冊日期</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% pendingUsers.forEach(u => { %>
            <tr>
              <td><strong><%= u.name %></strong></td>
              <td><%= u.email %></td>
              <td><%= u.role === 'manager' ? '主管' : '業務' %></td>
              <td><%= u.createdAt.toISOString().split('T')[0] %></td>
              <td>
                <form action="/admin/users/<%= u._id %>/approve?_method=PUT" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> 核准</button>
                </form>
                <form action="/admin/users/<%= u._id %>?_method=DELETE" method="POST" class="d-inline"
                  onsubmit="return confirm('確定拒絕並刪除此帳號？')">
                  <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-x-lg"></i> 拒絕</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<h4>已核准使用者</h4>
<div class="table-responsive">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>姓名</th>
        <th>Email</th>
        <th>角色</th>
        <th>所屬主管</th>
        <th>註冊日期</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% users.filter(u => u.isApproved).forEach(u => { %>
        <tr>
          <td><strong><%= u.name %></strong></td>
          <td><%= u.email %></td>
          <td>
            <form action="/admin/users/<%= u._id %>?_method=PUT" method="POST" class="d-inline role-form">
              <select name="role" class="form-select form-select-sm d-inline" style="width: auto;"
                onchange="this.form.submit()">
                <option value="sales" <%= u.role === 'sales' ? 'selected' : '' %>>業務</option>
                <option value="manager" <%= u.role === 'manager' ? 'selected' : '' %>>主管</option>
                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
              </select>
            </form>
          </td>
          <td>
            <% if (u.role === 'sales') { %>
              <form action="/admin/users/<%= u._id %>?_method=PUT" method="POST" class="d-inline">
                <select name="manager" class="form-select form-select-sm d-inline" style="width: auto;"
                  onchange="this.form.submit()">
                  <option value="none">未指派</option>
                  <% managers.forEach(m => { %>
                    <option value="<%= m._id %>" <%= u.manager && u.manager.toString() === m._id.toString() ? 'selected' : '' %>>
                      <%= m.name %>
                    </option>
                  <% }) %>
                </select>
              </form>
            <% } else { %>
              -
            <% } %>
          </td>
          <td><%= u.createdAt.toISOString().split('T')[0] %></td>
          <td>
            <% if (u._id.toString() !== user._id.toString()) { %>
              <form action="/admin/users/<%= u._id %>?_method=DELETE" method="POST" class="d-inline"
                onsubmit="return confirm('確定刪除此使用者？')">
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
