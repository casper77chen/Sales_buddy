<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card mt-3">
      <div class="card-header">
        <i class="bi bi-building"></i> <%= client ? '編輯客戶' : '新增客戶' %>
      </div>
      <div class="card-body p-4">
        <form action="<%= client ? '/clients/' + client._id + '?_method=PUT' : '/clients' %>" method="POST">
          <div class="mb-3">
            <label for="name" class="form-label">客戶名稱（診所）<span class="text-danger">*</span></label>
            <input type="text" name="name" id="name" class="form-control" placeholder="例：微笑牙醫診所"
              value="<%= client ? client.name : '' %>" required>
          </div>
          <div class="mb-3">
            <label for="contactPerson" class="form-label">聯絡人</label>
            <input type="text" name="contactPerson" id="contactPerson" class="form-control" placeholder="例：王醫師"
              value="<%= client ? client.contactPerson || '' : '' %>">
          </div>
          <div class="mb-3">
            <label for="phone" class="form-label">電話</label>
            <input type="text" name="phone" id="phone" class="form-control" placeholder="例：02-2345-6789"
              value="<%= client ? client.phone || '' : '' %>">
          </div>
          <div class="mb-3">
            <label for="address" class="form-label">地址</label>
            <input type="text" name="address" id="address" class="form-control" placeholder="例：台北市大安區忠孝東路三段100號"
              value="<%= client ? client.address || '' : '' %>">
          </div>
          <div class="mb-3">
            <label for="notes" class="form-label">備註</label>
            <textarea name="notes" id="notes" class="form-control" rows="3"
              placeholder="任何備註..."><%= client ? client.notes || '' : '' %></textarea>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><%= client ? '儲存' : '新增' %></button>
            <a href="/clients" class="btn btn-outline-secondary">取消</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
