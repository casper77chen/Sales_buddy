<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-building"></i> 客戶管理 <small class="text-muted fs-6">(<%= clients.length %> 筆)</small></h2>
  <div>
    <a href="/clients/import/csv" class="btn btn-outline-primary me-2"><i class="bi bi-upload"></i> CSV 匯入</a>
    <a href="/clients/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> 新增客戶</a>
  </div>
</div>

<form action="/clients" method="GET" class="mb-3">
  <div class="row g-2">
    <div class="col-md-3">
      <input type="text" name="search" class="form-control" placeholder="搜尋診所名稱、聯絡人、地址..."
        value="<%= typeof search !== 'undefined' ? search : '' %>">
    </div>
    <div class="col-md-2">
      <select name="rep" class="form-select" onchange="this.form.submit()">
        <option value="">全部業務</option>
        <option value="unassigned" <%= repFilter === 'unassigned' ? 'selected' : '' %>>未指派</option>
        <% salesReps.forEach(r => { %>
          <option value="<%= r._id %>" <%= repFilter === r._id.toString() ? 'selected' : '' %>><%= r.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <select name="city" class="form-select" onchange="this.form.submit()">
        <option value="">全部縣市</option>
        <% cities.forEach(c => { %>
          <option value="<%= c %>" <%= cityFilter === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    </div>
    <% if (districts.length > 0) { %>
      <div class="col-md-2">
        <select name="district" class="form-select" onchange="this.form.submit()">
          <option value="">全部行政區</option>
          <% districts.forEach(d => { %>
            <option value="<%= d %>" <%= districtFilter === d ? 'selected' : '' %>><%= d %></option>
          <% }) %>
        </select>
      </div>
    <% } %>
    <div class="col-md-2">
      <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i> 搜尋</button>
      <% if (search || cityFilter || districtFilter || repFilter) { %>
        <a href="/clients" class="btn btn-outline-secondary">清除</a>
      <% } %>
    </div>
  </div>
</form>

<% if (clients.length === 0) { %>
  <div class="text-center text-muted mt-5">
    <i class="bi bi-building" style="font-size: 3rem;"></i>
    <p class="mt-2">尚無客戶資料</p>
    <a href="/clients/new" class="btn btn-primary">新增第一位客戶</a>
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>d+</th>
          <th>HIS</th>
          <th>股東</th>
          <th>診所名稱</th>
          <th>電話</th>
          <th>縣市</th>
          <th>行政區</th>
          <th>地址</th>
          <th>負責業務</th>
          <th>負責人</th>
          <th>聯絡人</th>
          <th>機構代碼</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% clients.forEach(client => { %>
          <tr>
            <td class="text-center"><span class="status-dot <%= client.hasDPlus ? 'dot-on-dplus' : 'dot-off' %>"></span></td>
            <td class="text-center"><span class="status-dot <%= client.hasHIS ? 'dot-on-his' : 'dot-off' %>"></span></td>
            <td class="text-center"><span class="status-dot <%= client.isShareholder ? 'dot-on-shareholder' : 'dot-off' %>"></span></td>
            <td>
              <strong><%= client.name %></strong>
              <% if (client.website) { %>
                <a href="<%= client.website %>" target="_blank" class="ms-1"><i class="bi bi-globe"></i></a>
              <% } %>
              <% if (client.facebook) { %>
                <a href="<%= client.facebook %>" target="_blank" class="ms-1"><i class="bi bi-facebook"></i></a>
              <% } %>
            </td>
            <td><%= client.phone || '-' %></td>
            <td><%= client.city || '-' %></td>
            <td><%= client.district || '-' %></td>
            <td><small><%= client.address || '-' %></small></td>
            <td><%= client.assignedTo ? client.assignedTo.name : '-' %></td>
            <td><%= client.owner || '-' %></td>
            <td><%= client.contactPerson || '-' %></td>
            <td><small><%= client.institutionCode || '-' %></small></td>
            <td>
              <a href="/clients/<%= client._id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <form action="/clients/<%= client._id %>?_method=DELETE" method="POST" class="d-inline"
                onsubmit="return confirm('確定要刪除此客戶嗎？')">
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
