<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-fuel-pump"></i> <%= canReview ? '油資申報/審查' : '我的油資申報' %></h2>
</div>

<% if (canReview && pendingClaims.length > 0) { %>
  <h4><i class="bi bi-clipboard-check"></i> 待審油資 <span class="badge bg-danger"><%= pendingClaims.length %></span></h4>

  <%
    // 依申報人分組
    const grouped = {};
    pendingClaims.forEach(claim => {
      const repId = claim.salesRep ? claim.salesRep._id.toString() : 'unknown';
      if (!grouped[repId]) {
        grouped[repId] = { name: claim.salesRep ? claim.salesRep.name : '-', claims: [] };
      }
      grouped[repId].claims.push(claim);
    });
  %>

  <form action="/mileage/batch-approve" method="POST" id="batchForm">
    <% Object.keys(grouped).forEach((repId, idx) => { %>
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;"
          data-bs-toggle="collapse" data-bs-target="#rep-<%= idx %>">
          <div>
            <strong><%= grouped[repId].name %></strong>
            <span class="badge bg-secondary ms-2"><%= grouped[repId].claims.length %> 筆</span>
            <span class="badge bg-success ms-1">$<%= grouped[repId].claims.reduce((sum, c) => sum + (c.cost || Math.round(c.distanceKm * 6)), 0) %></span>
          </div>
          <div class="d-flex align-items-center gap-2">
            <button type="submit" class="btn btn-sm btn-success" onclick="event.stopPropagation(); selectGroup(<%= idx %>);">
              <i class="bi bi-check-all"></i> 全部核准
            </button>
            <i class="bi bi-chevron-down"></i>
          </div>
        </div>
        <div class="collapse" id="rep-<%= idx %>">
          <div class="card-body p-0">
            <table class="table table-hover mb-0">
              <thead>
                <tr>
                  <th>拜訪日期</th>
                  <th>送審日期</th>
                  <th>客戶</th>
                  <th>出發地</th>
                  <th>目的地</th>
                  <th>距離</th>
                  <th>費用</th>
                  <th>操作</th>
                </tr>
              </thead>
              <tbody>
                <% grouped[repId].claims.forEach(claim => { %>
                  <tr>
                    <td><%= claim.visit && claim.visit.date ? claim.visit.date.toISOString().split('T')[0] : '-' %></td>
                    <td><%= claim.createdAt.toISOString().split('T')[0] %></td>
                    <td><%= claim.visit && claim.visit.client ? claim.visit.client.name : '-' %></td>
                    <td><small><%= claim.originAddress %></small></td>
                    <td><small><%= claim.destinationAddress %></small></td>
                    <td><%= claim.distanceText || claim.distanceKm + ' km' %></td>
                    <td>$<%= claim.cost || Math.round(claim.distanceKm * 6) %></td>
                    <td>
                      <input type="checkbox" name="claimIds" value="<%= claim._id %>" class="group-<%= idx %> d-none">
                      <form action="/mileage/<%= claim._id %>?_method=PUT" method="POST" class="d-inline">
                        <input type="hidden" name="action" value="approve">
                        <button type="submit" class="btn btn-sm btn-outline-success"><i class="bi bi-check-lg"></i></button>
                      </form>
                      <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="collapse" data-bs-target="#reject-<%= claim._id %>">
                        <i class="bi bi-x-lg"></i>
                      </button>
                      <div class="collapse mt-2" id="reject-<%= claim._id %>">
                        <form action="/mileage/<%= claim._id %>?_method=PUT" method="POST">
                          <input type="hidden" name="action" value="reject">
                          <div class="input-group input-group-sm">
                            <input type="text" name="reviewNote" class="form-control" placeholder="駁回原因...">
                            <button type="submit" class="btn btn-danger">確認駁回</button>
                          </div>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% }) %>
  </form>
  <hr>
<% } else if (canReview) { %>
  <div class="alert alert-info mb-4"><i class="bi bi-info-circle"></i> 目前沒有待審油資</div>
<% } %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0"><i class="bi bi-list-check"></i> 我的油資申報</h4>
  <div class="d-flex align-items-center gap-2">
    <form class="d-flex align-items-center gap-2" method="GET" action="/mileage" id="filterForm">
      <label for="month" class="form-label mb-0 text-nowrap">拜訪月份</label>
      <input type="month" id="month" name="month" class="form-control form-control-sm" style="width: 170px;"
        value="<%= month %>" onchange="document.getElementById('filterForm').submit();">
      <% if (month) { %>
        <a href="/mileage" class="btn btn-sm btn-outline-secondary text-nowrap">清除</a>
      <% } %>
    </form>
    <a href="/mileage/export<%= month ? '?month=' + month : '' %>" class="btn btn-sm btn-outline-success text-nowrap">
      <i class="bi bi-download"></i> 匯出 CSV
    </a>
  </div>
</div>
<% if (claims.length === 0) { %>
  <div class="text-center text-muted mt-4">
    <i class="bi bi-fuel-pump" style="font-size: 3rem;"></i>
    <p class="mt-2">尚無油資申報記錄</p>
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>拜訪日期</th>
          <th>送審日期</th>
          <th>客戶</th>
          <th>出發地</th>
          <th>目的地</th>
          <th>距離</th>
          <th>費用</th>
          <th>狀態</th>
          <th>審核備註</th>
        </tr>
      </thead>
      <tbody>
        <% claims.forEach(claim => { %>
          <tr>
            <td><%= claim.visit && claim.visit.date ? claim.visit.date.toISOString().split('T')[0] : '-' %></td>
            <td><%= claim.createdAt.toISOString().split('T')[0] %></td>
            <td><%= claim.visit && claim.visit.client ? claim.visit.client.name : '-' %></td>
            <td><%= claim.originAddress %></td>
            <td><%= claim.destinationAddress %></td>
            <td><%= claim.distanceText || claim.distanceKm + ' km' %></td>
            <td>$<%= claim.cost || Math.round(claim.distanceKm * 6) %></td>
            <td>
              <% if (claim.status === 'pending') { %>
                <span class="badge bg-warning text-dark">待審核</span>
              <% } else if (claim.status === 'approved') { %>
                <span class="badge bg-success">已核准</span>
              <% } else { %>
                <span class="badge bg-danger">已駁回</span>
              <% } %>
            </td>
            <td><%= claim.reviewNote || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<% if (canReview && pendingClaims.length > 0) { %>
<script>
function selectGroup(idx) {
  document.querySelectorAll('.group-' + idx).forEach(cb => cb.checked = true);
  document.getElementById('batchForm').submit();
}
</script>
<% } %>
